{
  "rewrites": [
    { "source": "/sobre", "destination": "/src/pages/sobre.html" },
    { "source": "/habitabilidad-digital", "destination": "/src/pages/habitabilidad-digital.html" },
    { "source": "/mapa-de-tu-mente", "destination": "/src/pages/mapa-de-tu-mente.html" },
    { "source": "/newsletter", "destination": "/newsletter/index.html" },
    { "source": "/newsletter/", "destination": "/newsletter/index.html" },
    { "source": "/newsletter/numero-01", "destination": "/newsletter/numero-01/index.html" },
    { "source": "/newsletter/numero-01/", "destination": "/newsletter/numero-01/index.html" },
    { "source": "/archivo", "destination": "/src/pages/archivo.html" },
    { "source": "/archivo/", "destination": "/src/pages/archivo.html" },
    { "source": "/contacto", "destination": "/src/pages/contacto.html" },
    { "source": "/contacto/", "destination": "/src/pages/contacto.html" },
    { "source": "/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/public/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/styles/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
