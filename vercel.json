{
  "redirects": [
    { "source": "/sobre.html", "destination": "/sobre/", "permanent": true },
    { "source": "/archivo.html", "destination": "/archivo/", "permanent": true },
    { "source": "/conceptos.html", "destination": "/conceptos/", "permanent": true },
    { "source": "/contacto.html", "destination": "/contacto/", "permanent": true },
    { "source": "/newsletter.html", "destination": "/newsletter/", "permanent": true },
    { "source": "/habitabilidad-digital.html", "destination": "/habitabilidad-digital/", "permanent": true },
    { "source": "/mapa-de-tu-mente.html", "destination": "/mapa-de-tu-mente/", "permanent": true },
    { "source": "/economia-contemporanea.html", "destination": "/economia-contemporanea/", "permanent": true },
    { "source": "/glosario.html", "destination": "/glosario/", "permanent": true },
    { "source": "/criterio.html", "destination": "/criterio/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/public/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/styles/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
